<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns:fx="http://javafx.com/fxml" 
            fx:id="rootPane"
            fx:controller="com.comp2042.LevelGameOverController"
            prefWidth="900" 
            prefHeight="800"
            styleClass="level-gameover-root">
    
    
    <!-- Top: Title Section -->
    <top>
        <VBox alignment="CENTER" spacing="8" styleClass="title-section">
            <padding>
                <Insets top="30" bottom="10" left="40" right="40"/>
            </padding>
            
            <!-- Main Title -->
            <Label fx:id="mainTitleLabel" 
                   text="LEVEL COMPLETE" 
                   styleClass="main-title"/>
            
            <!-- Level Name Display -->
            <Label fx:id="levelNameLabel" 
                   text="" 
                   styleClass="level-name-display"
                   visible="false">
                <VBox.margin>
                    <Insets top="0" bottom="0" left="0" right="0"/>
                </VBox.margin>
            </Label>
            
            <!-- Stars Display -->
            <HBox fx:id="starsDisplay" 
                  alignment="CENTER" 
                  spacing="15"
                  styleClass="stars-container">
                <padding>
                    <Insets top="5" bottom="5" left="0" right="0"/>
                </padding>
            </HBox>
            
            <!-- Your Score Card -->
            <VBox fx:id="yourScoreCard" 
                  alignment="CENTER" 
                  spacing="5" 
                  styleClass="score-card">
                <VBox.margin>
                    <Insets top="5" bottom="5"/>
                </VBox.margin>
                <padding>
                    <Insets top="12" bottom="12" left="20" right="20"/>
                </padding>
                
                <Label text="YOUR SCORE" styleClass="card-title"/>
                <Label fx:id="finalScoreLabel" 
                       text="0" 
                       styleClass="final-score"/>
                
                <HBox spacing="30" alignment="CENTER">
                    <VBox alignment="CENTER" spacing="5">
                        <Label text="LINES" styleClass="stat-label"/>
                        <Label fx:id="linesLabel" text="0/0" styleClass="stat-value"/>
                    </VBox>
                    <VBox alignment="CENTER" spacing="5">
                        <Label text="TIME" styleClass="stat-label"/>
                        <Label fx:id="timeLabel" text="00:00" styleClass="stat-value"/>
                    </VBox>
                </HBox>
            </VBox>
            
            <!-- Best Stats Section -->
            <VBox fx:id="bestStatsSection" 
                  alignment="CENTER" 
                  spacing="5" 
                  styleClass="best-stats-section">
                <VBox.margin>
                    <Insets top="5" bottom="5"/>
                </VBox.margin>
                <padding>
                    <Insets top="12" bottom="12" left="20" right="20"/>
                </padding>
                
                <Label text="⭐ BEST STATS ⭐" styleClass="best-stats-title"/>
                
                <HBox spacing="30" alignment="CENTER">
                    <VBox alignment="CENTER" spacing="5">
                        <Label text="BEST SCORE" styleClass="stat-label"/>
                        <Label fx:id="bestScoreLabel" text="0" styleClass="stat-value"/>
                    </VBox>
                    <VBox alignment="CENTER" spacing="5">
                        <Label text="BEST TIME" styleClass="stat-label"/>
                        <Label fx:id="bestTimeLabel" text="--:--" styleClass="stat-value"/>
                    </VBox>
                </HBox>
            </VBox>
            
            <!-- Subtitle (for level failed) - Hidden -->
            <Label fx:id="subtitleLabel" 
                   text="" 
                   styleClass="subtitle"
                   visible="false"/>
        </VBox>
    </top>
    
    <!-- Center: Empty -->
    <center>
        <Pane/>
    </center>
    
    <!-- Bottom: Action Buttons -->
    <bottom>
        <VBox alignment="CENTER" spacing="8" styleClass="button-section">
            <padding>
                <Insets top="20" bottom="30" left="10" right="10"/>
            </padding>
            
            <HBox spacing="8" alignment="CENTER">
                <Button fx:id="tryAgainButton" 
                        text="🔄 TRY AGAIN" 
                        styleClass="action-button try-again-btn"
                        mnemonicParsing="false"
                        onAction="#onTryAgain"/>

                <Button fx:id="nextLevelButton" 
                        text="▶ NEXT LEVEL" 
                        styleClass="action-button next-level-btn"
                        mnemonicParsing="false"
                        visible="false"
                        managed="false"
                        onAction="#onNextLevel"/>

                <Button fx:id="backToSelectionButton" 
                        text=" 🔒 BACK TO SELECTION" 
                        styleClass="action-button selection-btn"
                        mnemonicParsing="false"
                        onAction="#onBackToSelection"/>

                <Button fx:id="backToMenuButton" 
                        text="🏠 BACK TO MENU" 
                        styleClass="action-button menu-btn"
                        mnemonicParsing="false"
                        onAction="#onBackToMenu"/>
            </HBox>
            
            <!-- Additional Info -->
            <Label text="Press N to try again or ESC to return to menu" 
                   styleClass="hint-text"/>
        </VBox>
    </bottom>
    
</BorderPane>
