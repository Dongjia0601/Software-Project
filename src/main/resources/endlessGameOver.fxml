<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns:fx="http://javafx.com/fxml" 
            fx:controller="com.comp2042.EndlessGameOverController"
            prefWidth="900" 
            prefHeight="800"
            styleClass="endless-gameover-root">
    
    
    <!-- Top: Title Section -->
    <top>
        <VBox alignment="CENTER" spacing="2" styleClass="title-section">
            <padding>
                <Insets top="10" bottom="0" left="40" right="40"/>
            </padding>
            
            <!-- Main Title -->
            <Label fx:id="mainTitleLabel" 
                   text="GAME OVER" 
                   styleClass="main-title"/>
            
            <!-- Subtitle (for new high score) -->
            <Label fx:id="subtitleLabel" 
                   text="" 
                   styleClass="subtitle"
                   visible="false"/>
            
            <!-- Rank Display -->
            <Label fx:id="rankLabel" 
                   text="" 
                   styleClass="rank-display"
                   visible="false"/>
        </VBox>
    </top>
    
    <!-- Center: Score and Leaderboard Section -->
    <center>
        <VBox alignment="CENTER" spacing="8" styleClass="center-section">
            <padding>
                <Insets top="0" bottom="5" left="40" right="40"/>
            </padding>
            
            <!-- Your Score Card -->
            <VBox fx:id="yourScoreCard" 
                  alignment="CENTER" 
                  spacing="5" 
                  styleClass="score-card">
                <padding>
                    <Insets top="12" bottom="12" left="20" right="20"/>
                </padding>
                
                <Label text="YOUR SCORE" styleClass="card-title"/>
                <Label fx:id="finalScoreLabel" 
                       text="0" 
                       styleClass="final-score"/>
                
                <HBox spacing="30" alignment="CENTER">
                    <VBox alignment="CENTER" spacing="5">
                        <Label text="LINES" styleClass="stat-label"/>
                        <Label fx:id="linesLabel" text="0" styleClass="stat-value"/>
                    </VBox>
                    <VBox alignment="CENTER" spacing="5">
                        <Label text="TIME" styleClass="stat-label"/>
                        <Label fx:id="timeLabel" text="00:00" styleClass="stat-value"/>
                    </VBox>
                </HBox>
            </VBox>
            
            <!-- Leaderboard Section -->
            <VBox fx:id="leaderboardSection" 
                  alignment="CENTER" 
                  spacing="5" 
                  styleClass="leaderboard-section">
                <padding>
                    <Insets top="12" bottom="12" left="20" right="20"/>
                </padding>
                
                <Label text="🏆 LEADERBOARD 🏆" styleClass="leaderboard-title"/>
                
                <VBox fx:id="leaderboardContainer" 
                      alignment="CENTER" 
                      spacing="8"
                      styleClass="leaderboard-container"/>
            </VBox>
        </VBox>
    </center>
    
    <!-- Bottom: Action Buttons -->
    <bottom>
        <VBox alignment="CENTER" spacing="5" styleClass="button-section">
            <padding>
                <Insets top="5" bottom="15" left="40" right="40"/>
            </padding>
            
            <HBox spacing="30" alignment="CENTER">
                <Button fx:id="tryAgainButton" 
                        text="🔄 TRY AGAIN" 
                        styleClass="action-button try-again-btn"
                        onAction="#onTryAgain"/>

                <Button fx:id="backToMenuButton" 
                        text="🏠 BACK TO MENU" 
                        styleClass="action-button menu-btn"
                        onAction="#onBackToMenu"/>
            </HBox>
            
            <!-- Additional Info -->
            <Label text="Press SPACE to try again or ESC to return to menu" 
                   styleClass="hint-text"/>
        </VBox>
    </bottom>
    
</BorderPane>
