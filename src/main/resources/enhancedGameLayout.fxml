<?xml version="1.0" encoding="UTF-8"?>

<?import com.comp2042.GameOverPanel?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.Group?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Text?>
<?import javafx.geometry.Insets?>
<?import java.net.URL?>

<BorderPane xmlns:fx="http://javafx.com/fxml" 
            fx:id="rootPane"
            fx:controller="com.comp2042.GuiController"
            prefWidth="900" 
            prefHeight="800"
            styleClass="root-pane">
    
    <!-- Left Panel: Hold Area and Statistics -->
    <left>
        <VBox spacing="20" styleClass="side-panel" prefWidth="230">
            <padding>
                <Insets top="20" right="15" bottom="20" left="15"/>
            </padding>
            
            <!-- Hold Area -->
            <VBox spacing="10" styleClass="info-box">
                <Label text="HOLD" styleClass="section-title"/>
                <GridPane fx:id="holdPanel" 
                         hgap="1" 
                         vgap="1" 
                         styleClass="hold-display"
                         alignment="CENTER"
                         minWidth="120" minHeight="120"
                         prefWidth="120" prefHeight="120"
                         maxWidth="120" maxHeight="120"/>
                <Label fx:id="holdHintLabel" 
                       text="Press SHIFT to Hold" 
                       styleClass="hint-label"/>
            </VBox>
            
            <!-- Game Statistics (for both endless and level modes) -->
            <VBox fx:id="statisticsBox" spacing="10" styleClass="info-box" managed="true" visible="true">
                <Label text="STATISTICS" styleClass="section-title"/>
                <HBox spacing="5">
                    <Label text="Level:" styleClass="stat-label"/>
                    <Label fx:id="levelLabel" text="1" styleClass="stat-value"/>
                </HBox>
                <HBox spacing="5">
                    <Label text="Lines:" styleClass="stat-label"/>
                    <Label fx:id="linesLabel" text="0" styleClass="stat-value"/>
                </HBox>
                <HBox spacing="5">
                    <Label text="Speed:" styleClass="stat-label"/>
                    <Label fx:id="speedLabel" text="1x" styleClass="stat-value"/>
                </HBox>
                <HBox spacing="5">
                    <Label text="Time:" styleClass="stat-label"/>
                    <Label fx:id="timeLabel" text="00:00" styleClass="stat-value"/>
                </HBox>
            </VBox>
            
            <!-- Objective (for level mode only) - Large font for better visibility -->
            <VBox fx:id="leftObjectiveBox" spacing="10" styleClass="info-box" managed="false" visible="false">
                <Label text="OBJECTIVE" styleClass="section-title"/>
                <HBox spacing="5" alignment="CENTER_LEFT">
                    <Label text="Time:" styleClass="stat-label"/>
                    <Label fx:id="leftTimerLabel" text="3:00" styleClass="stat-value-large"/>
                </HBox>
                <HBox spacing="5" alignment="CENTER_LEFT">
                    <Label text="Lines:" styleClass="stat-label"/>
                    <Label fx:id="leftProgressLabel" text="0/4" styleClass="stat-value-large"/>
                </HBox>
                <HBox spacing="5" alignment="CENTER_LEFT">
                    <Label text="Speed:" styleClass="stat-label"/>
                    <Label fx:id="leftSpeedLabel" text="1.0x" styleClass="stat-value-large"/>
                </HBox>
                <HBox spacing="5" alignment="CENTER_LEFT">
                    <Label text="Stars:" styleClass="stat-label"/>
                    <HBox fx:id="leftStarDisplay" spacing="8" alignment="CENTER"/>
                </HBox>
            </VBox>
            
            <!-- Controls (left panel) -->
            <VBox spacing="10" styleClass="info-box">
                <Label text="CONTROLS" styleClass="section-title"/>
                <Button fx:id="settingsButton" 
                       text="Settings" 
                       styleClass="control-button"
                       onAction="#showSettings"/>
                <Button fx:id="helpButton" 
                       text="Help" 
                       styleClass="control-button"
                       onAction="#showHelp"/>
                <Button text="Back to Menu" 
                       styleClass="control-button"
                       onAction="#returnToMenu"/>
                <Button fx:id="backToSelectionButton"
                        text="Back to Selection" 
                        styleClass="control-button"
                        onAction="#returnToLevelSelection"
                        visible="false"
                        managed="false"/>
            </VBox>
            
        </VBox>
    </left>
    
    <!-- Center: Game Board - Absolutely centered below title -->
    <center>
        <StackPane alignment="CENTER">
            <VBox alignment="CENTER" spacing="10" fillWidth="false">
                <padding>
                    <Insets top="10" bottom="20" left="0" right="0"/>
                </padding>
                
                <!-- Game Title - Centered and moved up -->
                <Label fx:id="gameTitleLabel" text="TETRIS" styleClass="game-title" alignment="CENTER">
                    <VBox.margin>
                        <Insets left="0" right="0" top="0" bottom="5"/>
                    </VBox.margin>
                </Label>
                
                <!-- Game Area Container - Enlarged for better visibility
                 Original: 10 columns × 20 visible rows, 20px brick + 1px gap = 21px
                 Enlarged: 25px brick + 1px gap = 26px
                 Grid: 10*25 + 9*1 = 259px width, 20*25 + 19*1 = 519px height
                 Border: 15px, Padding: 35px left/right, 25px top/bottom
                 Total: 259 + 2*15 + 2*35 = 359px width, 519 + 2*15 + 25 + 5 + 20 = 599px height (added 20px bottom space) -->
            <Pane styleClass="game-container" prefWidth="359" prefHeight="599">
                <!-- Background Board (decorative border: 15px) - FIRST (bottom layer) -->
                <Pane styleClass="gameBoard" layoutX="0" layoutY="0" prefWidth="359" prefHeight="599" mouseTransparent="true"/>
                
                <!-- Game Grid - SECOND (game cells) 
                     Position: 15px (border) + 35px (padding) = 50px from left
                               15px (border) + 35px (padding) = 50px from top
                     Size: 10 columns × 20 rows = 259px × 519px
                     Grid lines created via cell borders in GuiController -->
                <GridPane fx:id="gamePanel" hgap="1" vgap="1" layoutX="50" layoutY="50" 
                          prefWidth="259" prefHeight="519"
                          styleClass="game-grid"/>
                
                <!-- Brick Panel (moving piece overlay) - THIRD (middle layer, visible on top)
                     Initial position set by Java code, max 4×4 brick = 104×104px (4*25px + 3*1px gaps)
                     CRITICAL: MUST use same gaps as gamePanel for perfect cell alignment! -->
                <!-- Render moving brick with absolute positioned children to avoid GridPane rounding -->
                <Pane fx:id="brickPanel" prefWidth="104" prefHeight="104"/>
                
                <!-- Ghost Panel (ghost piece preview) - FOURTH (middle layer, below moving brick)
                     Shows semi-transparent preview of where brick will land -->
                <Pane fx:id="ghostPanel" prefWidth="104" prefHeight="104"/>
                
                <!-- Notification Area (Game Over overlay) - LAST (top layer)
                     Centered in game board: game board is 259×519px at (50, 40)
                     Panel is ~240×160px, so center at: X=50+(259-240)/2≈60, Y=40+(519-160)/2≈220 -->
                <Group fx:id="groupNotification" layoutX="60" layoutY="220">
                    <VBox alignment="CENTER">
                        <GameOverPanel fx:id="gameOverPanel"/>
                    </VBox>
                </Group>
            </Pane>
            
            <!-- Control Instructions -->
            <VBox spacing="2" alignment="CENTER">
                <Label text="[A/D] Move  [W] Rotate(Clockwise) [F] Rotate Counter-Clockwise"
                       styleClass="control-hint"/>
                <Label text="[S] Soft Drop  [Space] Hard Drop  [Shift] Hold "
                       styleClass="control-hint"/>
            </VBox>
            </VBox>
        </StackPane>
    </center>
    
    <!-- Right Panel: Next Brick and Score -->
    <right>
        <VBox spacing="20" styleClass="side-panel" prefWidth="230">
            <padding>
                <Insets top="20" right="15" bottom="20" left="15"/>
            </padding>
            
            <!-- Next Brick Area -->
            <VBox spacing="10" styleClass="info-box">
                <Label text="NEXT" styleClass="section-title"/>
                <GridPane fx:id="nextBrickPanel" 
                         hgap="1" 
                         vgap="1" 
                         styleClass="next-display"
                         alignment="CENTER"
                         minWidth="120" minHeight="120"
                         prefWidth="120" prefHeight="120"
                         maxWidth="120" maxHeight="120"/>
            </VBox>
            
            <!-- Score Display -->
            <VBox spacing="10" styleClass="info-box">
                <Label text="SCORE" styleClass="section-title"/>
                <Label fx:id="scoreLabel" 
                       text="0" 
                       styleClass="score-display"/>
                <!-- Best score and time display for level mode -->
                <VBox fx:id="bestStatsBox" spacing="5" alignment="CENTER_LEFT" managed="false" visible="false">
                    <Label fx:id="bestScoreLabel" text="Best Score: 0" styleClass="high-score-label"/>
                    <Label fx:id="bestTimeLabel" text="Best Time: --:--" styleClass="high-score-label"/>
                </VBox>
                <!-- Fallback high score for non-level modes -->
                <Label fx:id="highScoreLabel" 
                       text="Best Score: 0" 
                       styleClass="high-score-label"/>
            </VBox>
            
            <!-- Level Mode Status (visible only in level mode) -->
            <VBox fx:id="levelStatusBox" spacing="10" styleClass="info-box" managed="false" visible="false">
                <Label text="OBJECTIVE" styleClass="section-title"/>
                <HBox spacing="5" alignment="CENTER_LEFT">
                    <Label text="Time:" styleClass="stat-label"/>
                    <Label fx:id="timerLabel" text="3:00" styleClass="stat-value-large"/>
                </HBox>
                <HBox spacing="5" alignment="CENTER_LEFT">
                    <Label text="Lines:" styleClass="stat-label"/>
                    <Label fx:id="progressLabel" text="0/20" styleClass="stat-value-large"/>
                </HBox>
                <VBox spacing="5">
                    <Label text="Stars:" styleClass="stat-label"/>
                    <HBox fx:id="starDisplay" spacing="8" alignment="CENTER"/>
                </VBox>
            </VBox>
            
            <!-- Actions -->
            <VBox spacing="10" styleClass="info-box">
                <Label text="ACTIONS" styleClass="section-title"/>
                <Button text="New Game (N)" 
                       styleClass="game-button"
                       onAction="#newGame"/>
                <Button fx:id="muteButton" 
                       text="MUTE (M)" 
                       styleClass="game-button"
                       onAction="#toggleMute"/>
                <Button fx:id="pauseButton" 
                       text="Pause/Resume (P)" 
                       styleClass="game-button"
                       onAction="#pauseGame"/>
            </VBox>
            
        </VBox>
    </right>
    
    <!-- Stylesheets -->
    <stylesheets>
        <URL value="@enhancedGameStyle.css"/>
    </stylesheets>
</BorderPane>
