<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Text?>

<StackPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.comp2042.ui.SettingsController"
           styleClass="settings-root">
    
    <VBox spacing="20" alignment="CENTER" styleClass="settings-container" maxWidth="700" maxHeight="600">
        <padding>
            <Insets top="20" right="40" bottom="20" left="40"/>
        </padding>
        
        <!-- Title -->
        <Text text="SETTINGS" styleClass="settings-title"/>
        
        <!-- Settings Content -->
        <ScrollPane fitToWidth="true" styleClass="settings-scroll" VBox.vgrow="ALWAYS" maxHeight="320">
            <VBox spacing="18" styleClass="settings-content">
                
                <!-- Controls Section -->
                <VBox spacing="10" styleClass="settings-section">
                    <Text text="CONTROLS" styleClass="section-title"/>
                    <Separator styleClass="section-divider"/>
                    
                    <VBox spacing="20" styleClass="controls-container">
                        <!-- Single Player Mode Controls -->
                        <VBox spacing="8" styleClass="control-section">
                            <Text text="Single Player Controls (Endless Mode / Level Mode)" styleClass="control-section-title"/>
                            <VBox spacing="4" styleClass="control-list">
                                <HBox spacing="20" alignment="CENTER_LEFT">
                                    <Label text="Move Left / Right" styleClass="control-action" minWidth="200"/>
                                    <Label text="A / D" styleClass="control-key"/>
                                </HBox>
                                <HBox spacing="20" alignment="CENTER_LEFT">
                                    <Label text="Rotate (Clockwise)" styleClass="control-action" minWidth="200"/>
                                    <Label text="W" styleClass="control-key"/>
                                </HBox>
                                <HBox spacing="20" alignment="CENTER_LEFT">
                                    <Label text="Rotate (Counterclockwise)" styleClass="control-action" minWidth="200"/>
                                    <Label text="F" styleClass="control-key"/>
                                </HBox>
                                <HBox spacing="20" alignment="CENTER_LEFT">
                                    <Label text="Soft Drop" styleClass="control-action" minWidth="200"/>
                                    <Label text="S" styleClass="control-key"/>
                                </HBox>
                                <HBox spacing="20" alignment="CENTER_LEFT">
                                    <Label text="Hard Drop" styleClass="control-action" minWidth="200"/>
                                    <Label text="Space" styleClass="control-key"/>
                                </HBox>
                                <HBox spacing="20" alignment="CENTER_LEFT">
                                    <Label text="Hold Block" styleClass="control-action" minWidth="200"/>
                                    <Label text="Shift" styleClass="control-key"/>
                                </HBox>
                            </VBox>
                        </VBox>
                        
                        <!-- Two Player Mode Controls -->
                        <VBox spacing="8" styleClass="control-section">
                            <Text text="Two-Player Controls (Two-Player Mode)" styleClass="control-section-title"/>
                            
                            <!-- Player 1 -->
                            <VBox spacing="4" styleClass="player-controls">
                                <Text text="Player 1" styleClass="player-title"/>
                                <VBox spacing="4" styleClass="control-list">
                                    <HBox spacing="20" alignment="CENTER_LEFT">
                                        <Label text="Move Left / Right" styleClass="control-action" minWidth="200"/>
                                        <Label text="A / D" styleClass="control-key"/>
                                    </HBox>
                                    <HBox spacing="20" alignment="CENTER_LEFT">
                                        <Label text="Rotate (Clockwise)" styleClass="control-action" minWidth="200"/>
                                        <Label text="W" styleClass="control-key"/>
                                    </HBox>
                                    <HBox spacing="20" alignment="CENTER_LEFT">
                                        <Label text="Rotate (Counterclockwise)" styleClass="control-action" minWidth="200"/>
                                        <Label text="F" styleClass="control-key"/>
                                    </HBox>
                                    <HBox spacing="20" alignment="CENTER_LEFT">
                                        <Label text="Soft Drop" styleClass="control-action" minWidth="200"/>
                                        <Label text="S" styleClass="control-key"/>
                                    </HBox>
                                    <HBox spacing="20" alignment="CENTER_LEFT">
                                        <Label text="Hard Drop" styleClass="control-action" minWidth="200"/>
                                        <Label text="Space" styleClass="control-key"/>
                                    </HBox>
                                    <HBox spacing="20" alignment="CENTER_LEFT">
                                        <Label text="Hold Block" styleClass="control-action" minWidth="200"/>
                                        <Label text="Shift" styleClass="control-key"/>
                                    </HBox>
                                </VBox>
                            </VBox>
                            
                            <!-- Player 2 -->
                            <VBox spacing="4" styleClass="player-controls">
                                <Text text="Player 2" styleClass="player-title"/>
                                <VBox spacing="4" styleClass="control-list">
                                    <HBox spacing="20" alignment="CENTER_LEFT">
                                        <Label text="Move Left / Right" styleClass="control-action" minWidth="200"/>
                                        <Label text="← / →" styleClass="control-key"/>
                                    </HBox>
                                    <HBox spacing="20" alignment="CENTER_LEFT">
                                        <Label text="Rotate (Clockwise)" styleClass="control-action" minWidth="200"/>
                                        <Label text="↑" styleClass="control-key"/>
                                    </HBox>
                                    <HBox spacing="20" alignment="CENTER_LEFT">
                                        <Label text="Rotate (Counterclockwise)" styleClass="control-action" minWidth="200"/>
                                        <Label text="2 / NumPad2" styleClass="control-key"/>
                                    </HBox>
                                    <HBox spacing="20" alignment="CENTER_LEFT">
                                        <Label text="Soft Drop" styleClass="control-action" minWidth="200"/>
                                        <Label text="↓" styleClass="control-key"/>
                                    </HBox>
                                    <HBox spacing="20" alignment="CENTER_LEFT">
                                        <Label text="Hard Drop" styleClass="control-action" minWidth="200"/>
                                        <Label text="0 / NumPad0" styleClass="control-key"/>
                                    </HBox>
                                    <HBox spacing="20" alignment="CENTER_LEFT">
                                        <Label text="Hold Block" styleClass="control-action" minWidth="200"/>
                                        <Label text="1 / NumPad1" styleClass="control-key"/>
                                    </HBox>
                                </VBox>
                            </VBox>
                        </VBox>
                        
                <!-- Game Controls -->
                        <VBox spacing="4" styleClass="control-section">
                            <Text text="Controls" styleClass="control-section-title"/>
                            <VBox spacing="4" styleClass="control-list">
                                <HBox spacing="20" alignment="CENTER_LEFT">
                                    <Label text="Pause/Resume" styleClass="control-action" minWidth="200"/>
                                    <Label text="P" styleClass="control-key"/>
                                </HBox>
                                <HBox spacing="20" alignment="CENTER_LEFT">
                                    <Label text="New Game" styleClass="control-action" minWidth="200"/>
                                    <Label text="N" styleClass="control-key"/>
                                </HBox>
                                <HBox spacing="20" alignment="CENTER_LEFT">
                                    <Label text="Mute / Unmute" styleClass="control-action" minWidth="200"/>
                                    <Label text="M" styleClass="control-key"/>
                                </HBox>
                            </VBox>
                        </VBox>

                <!-- Gameplay Section -->
                <VBox spacing="10" styleClass="settings-section">
                    <Text text="GAMEPLAY" styleClass="section-title"/>
                    <Separator styleClass="section-divider"/>
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <Label text="Piece Randomizer:" styleClass="audio-label" minWidth="140"/>
                        <Region prefWidth="30" />
                        <ChoiceBox fx:id="randomizerChoice" prefWidth="260" styleClass="randomizer-choice"/>
                    </HBox>
                </VBox>
                    </VBox>
                </VBox>
                
                <!-- Audio Section -->
                <VBox spacing="10" styleClass="settings-section">
                    <Text text="AUDIO" styleClass="section-title"/>
                    <Separator styleClass="section-divider"/>
                    
                    <!-- Master Volume -->
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <Label text="Master Volume:" styleClass="audio-label" HBox.hgrow="NEVER" minWidth="140"/>
                        <Slider fx:id="masterVolumeSlider" min="0" max="100" value="70" 
                                showTickLabels="false" showTickMarks="false" 
                                styleClass="volume-slider" HBox.hgrow="ALWAYS"/>
                        <Label fx:id="masterVolumeLabel" text="70%" styleClass="volume-label" minWidth="45"/>
                    </HBox>
                    
                    <!-- Music Volume -->
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <Label text="Background Music:" styleClass="audio-label" HBox.hgrow="NEVER" minWidth="140"/>
                        <Slider fx:id="musicVolumeSlider" min="0" max="100" value="50" 
                                showTickLabels="false" showTickMarks="false" 
                                styleClass="volume-slider" HBox.hgrow="ALWAYS"/>
                        <Label fx:id="musicVolumeLabel" text="50%" styleClass="volume-label" minWidth="45"/>
                    </HBox>
                    
                    <!-- Sound Effects Volume -->
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <Label text="Sound Effects:" styleClass="audio-label" HBox.hgrow="NEVER" minWidth="140"/>
                        <Slider fx:id="sfxVolumeSlider" min="0" max="100" value="80" 
                                showTickLabels="false" showTickMarks="false" 
                                styleClass="volume-slider" HBox.hgrow="ALWAYS"/>
                        <Label fx:id="sfxVolumeLabel" text="80%" styleClass="volume-label" minWidth="45"/>
                    </HBox>
                </VBox>
                
            </VBox>
        </ScrollPane>
        
        <!-- All Action Buttons in One Row -->
        <HBox spacing="12" alignment="CENTER" styleClass="all-buttons-container">
            <Button fx:id="saveButton" text="Save" onAction="#saveSettings" styleClass="settings-button, save-button"/>
            <Button fx:id="resetButton" text="Reset" onAction="#resetToDefault" styleClass="settings-button, reset-button"/>
            <Button fx:id="backToGameButton" text="Back to Game" onAction="#backToGame" 
                   styleClass="settings-button, continue-button" visible="false" managed="false"/>
            <Button fx:id="backToMenuButton" text="Back to Menu" onAction="#backToMenu" 
                   styleClass="settings-button, exit-button"/>
        </HBox>
        
        <!-- Status Message -->
        <Label fx:id="statusLabel" text="" styleClass="status-label"/>
        
    </VBox>
    
</StackPane>
