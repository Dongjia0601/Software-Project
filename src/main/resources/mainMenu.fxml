<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.effect.Glow?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.paint.Color?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<AnchorPane fx:id="rootPane" 
            fx:controller="com.comp2042.MainMenuController"
            xmlns:fx="http://javafx.com/fxml"
            styleClass="main-menu-background"
            prefWidth="900.0"
            prefHeight="800.0">
    
    <!-- Main Content Container - Centered -->
    <VBox fx:id="mainContentContainer" 
          alignment="CENTER" 
          AnchorPane.leftAnchor="0.0"
          AnchorPane.rightAnchor="0.0"
          AnchorPane.topAnchor="0.0"
          AnchorPane.bottomAnchor="0.0"
          spacing="40.0">
        
        <!-- Title - Neon Tetris Logo -->
        <Text fx:id="titleText" 
              text="TETRIS" 
              styleClass="title-text"
              fill="#FF6BFF"
              textAlignment="CENTER">
            <font>
                <Font name="Impact" size="80.0"/>
            </font>
            <VBox.margin>
                <Insets top="-70.0" bottom="0.0" left="0.0" right="0.0"/>
            </VBox.margin>
            <!-- Effect will be enhanced in controller -->
        </Text>
        
        <!-- Subtitle -->
        <Label text="Choose Your Game Mode" textFill="#cccccc" textAlignment="CENTER">
            <font>
                <Font name="Segoe UI" size="18.0" />
            </font>
        </Label>
        
        <!-- Game Mode Buttons -->
        <VBox fx:id="modeButtonsContainer" 
              alignment="CENTER" 
              spacing="32.0">
        
        <Button fx:id="endlessModeBtn" 
                text="Endless Mode" 
                styleClass="mode-button"
                onAction="#startEndlessMode"
                style="-fx-background-color: linear-gradient(to bottom,rgba(77, 255, 255, 0.94),rgba(45, 184, 184, 0.69)); -fx-text-fill: #1A0033; -fx-border-color: #FF6BFF; -fx-border-width: 2; -fx-background-radius: 12; -fx-border-radius: 12; -fx-padding: 10 20; -fx-cursor: hand;">
            <font>
                <Font name="Segoe UI" size="18.0" style="bold"/>
            </font>
            <effect>
                <DropShadow color="#FF6BFF" radius="8" spread="0.4"/>
            </effect>
        </Button>
        
        <Button fx:id="levelModeBtn" 
                text="Level Mode" 
                styleClass="mode-button"
                onAction="#startLevelMode"
                style="-fx-background-color: linear-gradient(to bottom,rgba(255, 215, 0, 0.94),rgba(255, 165, 0, 0.69)); -fx-text-fill: #1A0033; -fx-border-color: #FF4D4D; -fx-border-width: 2; -fx-background-radius: 12; -fx-border-radius: 12; -fx-padding: 10 20; -fx-cursor: hand;">
            <font>
                <Font name="Segoe UI" size="18.0" style="bold"/>
            </font>
            <effect>
                <DropShadow color="#FF4D4D" radius="8" spread="0.4"/>
            </effect>
        </Button>
        
        <Button fx:id="aiModeBtn" 
                text="AI Mode" 
                styleClass="mode-button"
                onAction="#startAIMode"
                style="-fx-background-color: linear-gradient(to bottom,rgba(255, 107, 157, 0.94),rgba(255, 20, 147, 0.69)); -fx-text-fill: #1A0033; -fx-border-color: #8A2BE2; -fx-border-width: 2; -fx-background-radius: 12; -fx-border-radius: 12; -fx-padding: 10 20; -fx-cursor: hand;">
            <font>
                <Font name="Segoe UI" size="18.0" style="bold"/>
            </font>
            <effect>
                <DropShadow color="#8A2BE2" radius="8" spread="0.4"/>
            </effect>
        </Button>
        
        <Button fx:id="twoPlayerModeBtn" 
                text="Two-Player Mode" 
                styleClass="mode-button"
                onAction="#startTwoPlayerMode"
                style="-fx-background-color: linear-gradient(to bottom,rgba(107, 255, 107, 0.94),rgba(34, 139, 34, 0.69)); -fx-text-fill: #1A0033; -fx-border-color: #FF8C00; -fx-border-width: 2; -fx-background-radius: 12; -fx-border-radius: 12; -fx-padding: 10 20; -fx-cursor: hand;">
            <font>
                <Font name="Segoe UI" size="18.0" style="bold"/>
            </font>
            <effect>
                <DropShadow color="#FF8C00" radius="8" spread="0.4"/>
            </effect>
        </Button>
        
        </VBox>
        
    </VBox>
    
    <!-- Settings Button - Top Right Corner -->
    <Button fx:id="settingsBtn" 
            text="Settings" 
            layoutX="680.0" 
            layoutY="20.0"
            styleClass="settings-button"
            onAction="#openSettings"
            prefWidth="100.0"
            prefHeight="40.0"
            style="-fx-background-color: linear-gradient(to bottom,rgba(194, 109, 194, 0.94),rgba(137, 43, 226, 0.69)); -fx-text-fill: #1A0033; -fx-border-color: #FF6BFF; -fx-border-width: 2; -fx-background-radius: 12; -fx-border-radius: 12; -fx-padding: 10 18; -fx-cursor: hand;">
        <font>
            <Font name="Segoe UI" size="14.0" style="bold"/>
        </font>
        <effect>
            <DropShadow color="#FF6BFF" radius="8" spread="0.4"/>
        </effect>
    </Button>
    
    <!-- Help Button - Top Right Corner -->
    <Button fx:id="helpBtn" 
            text="Help" 
            layoutX="790.0"
            layoutY="20.0"
            styleClass="help-button"
            onAction="#showHelp"
            prefWidth="100.0"
            prefHeight="40.0"
            style="-fx-background-color: linear-gradient(to bottom,rgba(99, 215, 215, 0.73),rgba(23, 127, 161, 0.83)); -fx-text-fill: #1A0033; -fx-border-color: #4DFFFF; -fx-border-width: 2; -fx-background-radius: 12; -fx-border-radius: 12; -fx-padding: 10 16; -fx-cursor: hand;">
        <font>
            <Font name="Segoe UI" size="14.0" style="bold"/>
        </font>
        <effect>
            <DropShadow color="#4DFFFF" radius="8" spread="0.4"/>
        </effect>
    </Button>
    
</AnchorPane>
